# DYNAN META AI - Environment Variables
# JANGAN SHARE FILE INI! Simpan rahasia.

# DeepSeek API Key (isi dengan key asli Anda)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Model yang digunakan
DEEPSEEK_MODEL=deepseek-chat

# Optional: Max tokens per response
MAX_TOKENS=2000

# Optional: Temperature (kreativitas, 0-1)
TEMPERATURE=0.9
